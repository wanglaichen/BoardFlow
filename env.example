APP_HOST=0.0.0.0
APP_PORT=9213

# auto | redis | json
STORAGE_BACKEND=redis
REDIS_URL=redis://default:password@host:6379
REDIS_KEY_PREFIX=jjob:boardflow:state
REDIS_SETTINGS_KEY=jjob:boardflow:settings
REDIS_TIMEOUT_SECONDS=5

# 本地 JSON 回退文件（Redis 不可用时使用）
# DATA_DIR=data

# Optional debug mode
# APP_DEBUG=1
