APP_HOST=0.0.0.0
APP_PORT=9213

# 超级管理员（不进 Redis 用户表）
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change-me

# auto | redis | json
STORAGE_BACKEND=redis
REDIS_URL=redis://default:password@host:6379
REDIS_KEY_PREFIX=jjob:boardflow
REDIS_SETTINGS_KEY=jjob:boardflow:settings
REDIS_TIMEOUT_SECONDS=5

# 应用版本（可选，默认读取项目根目录 VERSION 文件）
# APP_VERSION=0.2.1

# 本地 JSON 回退文件（Redis 不可用时使用）
# DATA_DIR=data

# 多平台看板对比 — 联邦只读 API（Phase 0+）
# 两台实例需约定相同令牌；未启用时 /api/federation/* 返回 404
# FEDERATION_COMPARE_ENABLED=1
# FEDERATION_COMPARE_TOKEN=change-me-to-a-long-random-string
# 发起方连接远程时可选 host 白名单（逗号分隔）
# FEDERATION_ALLOWED_HOSTS=board-flow-wheat.vercel.app,127.0.0.1

# 对比编排（发起方）
# COMPARE_SESSION_TTL_SEC=3600
# COMPARE_REMOTE_TIMEOUT_SEC=30
# COMPARE_ACCOUNTS_PAGE_SIZE=20
# COMPARE_REMOTE_RETRY_COUNT=2
# COMPARE_RESULTS_PAGE_SIZE=20
# FEDERATION_ALLOW_PRIVATE_HOSTS=0

# Optional debug mode
# APP_DEBUG=1
